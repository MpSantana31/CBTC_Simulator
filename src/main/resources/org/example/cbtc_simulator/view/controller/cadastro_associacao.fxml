<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.cbtc_simulator.view.controller.CadastroAssociacaoController">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
    <Label text="Associacao Linha + Estacao (com ordem)" style="-fx-font-weight: bold;"/>
    <TableView fx:id="tabela" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colLinha" text="Linha" prefWidth="150"/>
            <TableColumn fx:id="colSentido" text="Sentido" prefWidth="80"/>
            <TableColumn fx:id="colEstacao" text="Estacao" prefWidth="200"/>
            <TableColumn fx:id="colOrdem" text="Ordem" prefWidth="80"/>
        </columns>
    </TableView>
    <GridPane hgap="10" vgap="5">
        <Label text="Linha:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="comboLinha" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>
        <Label text="Sentido:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="comboSentido" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="100"/>
        <Label text="Estacao:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ComboBox fx:id="comboEstacao" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="200"/>
        <Label text="Ordem:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="fieldOrdem" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="80"/>
    </GridPane>
    <HBox spacing="10">
        <Button text="Adicionar" onAction="#adicionar"/>
        <Button text="Excluir" onAction="#excluir"/>
        <Button text="Cancelar" onAction="#cancelar"/>
    </HBox>
</VBox>
