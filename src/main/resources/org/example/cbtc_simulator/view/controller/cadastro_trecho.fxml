<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.cbtc_simulator.view.controller.CadastroTrechoController">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
    <TableView fx:id="tabela" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colLinha" text="Linha" prefWidth="120"/>
            <TableColumn fx:id="colSentido" text="Sentido" prefWidth="80"/>
            <TableColumn fx:id="colOrigem" text="Origem" prefWidth="120"/>
            <TableColumn fx:id="colDestino" text="Destino" prefWidth="120"/>
            <TableColumn fx:id="colDistancia" text="Distancia" prefWidth="80"/>
            <TableColumn fx:id="colOrdem" text="Ordem" prefWidth="60"/>
        </columns>
    </TableView>
    <GridPane hgap="10" vgap="5">
        <Label text="Linha:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="fieldLinha" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Sentido:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="fieldSentido" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Est. Origem:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ComboBox fx:id="fieldEstacaoOrigem" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Label text="Est. Destino:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <ComboBox fx:id="fieldEstacaoDestino" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <Label text="Distancia Km:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="fieldDistanciaKm" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        <Label text="Ordem:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <TextField fx:id="fieldOrdem" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>
    <HBox spacing="10">
        <Button text="Salvar" onAction="#salvar"/>
        <Button text="Editar" onAction="#editar"/>
        <Button text="Excluir" onAction="#excluir"/>
        <Button text="Cancelar" onAction="#cancelar"/>
    </HBox>
</VBox>
